{
  "name": "@billmanager/mobile",
  "version": "1.0.0-alpha.1",
  "main": "index.ts",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.0",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "undici": "^7.18.2"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "i18n:sync": "node scripts/sync-web-translations.mjs",
    "i18n:check": "node scripts/sync-web-translations.mjs --check",
    "api:generate": "npx --yes openapi-typescript@7.13.0 ../server/openapi.yaml -o src/api/generated/schema.ts",
    "api:check": "npm run api:generate && git diff --exit-code -- src/api/generated/schema.ts",
    "prebuild": "npm run i18n:sync && expo prebuild --clean",
    "prebuild:development": "cross-env BILLMANAGER_DEVELOPMENT_BUILD=true npm run prebuild",
    "android": "cross-env BILLMANAGER_DEVELOPMENT_BUILD=true expo run:android",
    "ios": "cross-env BILLMANAGER_DEVELOPMENT_BUILD=true expo run:ios",
    "web": "expo start --web",
    "lint": "eslint --max-warnings=0 App.tsx app.config.ts src widgets modules",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "maestro:validate": "node scripts/validate-maestro-flows.mjs",
    "config:validate": "node scripts/validate-build-profiles.mjs",
    "doctor": "npx expo-doctor",
    "check": "npm run i18n:check && npm run api:check && npm run lint && npm run typecheck && npm test && npm run maestro:validate && npm run config:validate && npx expo install --check && npm run doctor"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@expo/ui": "~57.0.7",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.18.11",
    "@react-navigation/native": "^7.3.11",
    "@react-navigation/native-stack": "^7.18.3",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "babel-preset-expo": "~57.0.3",
    "date-fns": "^4.4.0",
    "expo": "~57.0.7",
    "expo-auth-session": "~57.0.4",
    "expo-background-task": "~57.0.5",
    "expo-build-properties": "~57.0.6",
    "expo-constants": "~57.0.5",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-local-authentication": "~57.0.1",
    "expo-localization": "~57.0.1",
    "expo-notifications": "~57.0.6",
    "expo-print": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-task-manager": "~57.0.5",
    "expo-updates": "~57.0.8",
    "expo-web-browser": "~57.0.1",
    "expo-widgets": "~57.0.6",
    "i18next": "^26.3.6",
    "lucide-react-native": "^1.25.0",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.82.0",
    "react-i18next": "^17.0.10",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "victory-native": "^41.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.2.17",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "private": true,
  "allowScripts": {
    "@shopify/react-native-skia@2.6.2": true
  }
}
